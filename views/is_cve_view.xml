<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="is_cve_view_tree" model="ir.ui.view">
        <field name="name">is.cve.tree</field>
        <field name="model">is.cve</field>
        <field name="arch" type="xml">
            <list string="CVE">
                <field name="cve_id"/>
                <field name="name"/>
                <field name="state"/>
                <field name="score_gravite" decoration-danger="score_gravite &gt;= 70" decoration-warning="score_gravite &gt;= 40 and score_gravite &lt; 70" decoration-success="score_gravite &lt; 40" widget="progressbar" options="{'max_value': 100, 'editable': False}"/>
                <field name="severity" decoration-danger="severity=='critical'" decoration-warning="severity=='high'" decoration-info="severity=='medium'" optional="show"/>
                <field name="cvss_score" optional="show"/>
                <field name="epss_score" optional="show"/>
                <field name="vendor" optional="show"/>
                <field name="product" optional="show"/>
                <field name="is_patch_available" optional="show"/>
                <field name="is_kev" optional="hide"/>
                <field name="is_poc" optional="hide"/>
                <field name="is_template" optional="hide"/>
                <field name="exposure_hosts" optional="hide"/>
                <field name="age_in_days" optional="hide"/>
                <field name="cve_created_at" optional="show"/>
                <field name="cve_updated_at" optional="show"/>
            </list>
        </field>
    </record>

    <record id="is_cve_view_form" model="ir.ui.view">
        <field name="name">is.cve.form</field>
        <field name="model">is.cve</field>
        <field name="arch" type="xml">
            <form string="CVE">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="creation,analyse,traite,non_concerne" options="{'clickable': true}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="cve_id" placeholder="CVE-XXXX-XXXXX"/></h1>
                        <h2><field name="name" placeholder="Nom de la vulnérabilité"/></h2>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="severity"/>
                            <field name="vuln_status"/>
                            <field name="vulnerability_type"/>
                            <field name="cwe_ids"/>
                            <field name="assignee"/>
                        </group>
                        <group string="Scores">
                            <field name="score_gravite" widget="progressbar" options="{'max_value': 100, 'editable': False}"/>
                            <field name="cvss_score"/>
                            <field name="cvss_metrics"/>
                            <field name="epss_score"/>
                            <field name="epss_percentile"/>
                            <field name="ntps"/>
                        </group>
                    </group>
                    <group>
                        <group string="Produit affecté">
                            <field name="vendor"/>
                            <field name="product"/>
                            <field name="exposure_hosts"/>
                            <field name="h1_rank"/>
                        </group>
                        <group string="Indicateurs">
                            <field name="is_patch_available"/>
                            <field name="is_remote"/>
                            <field name="is_auth"/>
                            <field name="is_kev"/>
                            <field name="is_poc"/>
                            <field name="is_template"/>
                        </group>
                    </group>
                    <group>
                        <group string="Prérequis">
                            <field name="requirement_type"/>
                            <field name="requirements"/>
                        </group>
                        <group string="Dates">
                            <field name="age_in_days"/>
                            <field name="cve_created_at"/>
                            <field name="cve_updated_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Analyse">
                            <field name="analyse" nolabel="1"/>
                        </page>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                        <page string="Impact">
                            <field name="impact" nolabel="1"/>
                        </page>
                        <page string="Remédiation">
                            <field name="remediation" nolabel="1"/>
                        </page>
                        <page string="Détail JSON">
                            <field name="json_detail" nolabel="1" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="is_cve_view_kanban" model="ir.ui.view">
        <field name="name">is.cve.kanban</field>
        <field name="model">is.cve</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="cve_id"/>
                <field name="name"/>
                <field name="severity"/>
                <field name="cvss_score"/>
                <field name="score_gravite"/>
                <field name="state"/>
                <field name="is_patch_available"/>
                <field name="vendor"/>
                <field name="product"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="cve_id"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <div class="badge text-bg-warning" style="font-size:0.85em;">
                                    Score: <field name="score_gravite"/> | CVSS: <field name="cvss_score"/>
                                </div>
                                <div t-if="record.severity.value" class="badge"
                                    t-attf-class="badge #{record.severity.raw_value == 'critical' ? 'text-bg-danger' : record.severity.raw_value == 'high' ? 'text-bg-warning' : record.severity.raw_value == 'medium' ? 'text-bg-info' : 'text-bg-secondary'}">
                                    <field name="severity"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="name"/>
                                <div t-if="record.vendor.value" class="text-muted">
                                    <i class="fa fa-tag"/> <field name="vendor"/> / <field name="product"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left"/>
                                <div class="oe_kanban_bottom_right">
                                    <span t-if="record.is_patch_available.raw_value" class="text-success">
                                        <i class="fa fa-check-circle"/> Patch
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="is_cve_view_search" model="ir.ui.view">
        <field name="name">is.cve.search</field>
        <field name="model">is.cve</field>
        <field name="arch" type="xml">
            <search string="CVE">
                <field name="cve_id"/>
                <field name="name"/>
                <field name="description" string="Description"/>
                <field name="json_detail" string="JSON"/>
                <filter name="critical" string="Critical" domain="[('severity','=','critical')]"/>
                <filter name="high"     string="High"     domain="[('severity','=','high')]"/>
                <filter name="no_patch" string="Sans patch" domain="[('is_patch_available','=',False)]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_state"    string="État"      context="{'group_by': 'state'}"/>
                    <filter name="group_severity" string="Sévérité"  context="{'group_by': 'severity'}"/>
                    <filter name="group_vendor"   string="Éditeur"   context="{'group_by': 'vendor'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="is_cve_action" model="ir.actions.act_window">
        <field name="name">CVE</field>
        <field name="res_model">is.cve</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>
