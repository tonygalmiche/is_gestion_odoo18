<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- is.serveur -->
    <record id="is_serveur_form" model="ir.ui.view">
        <field name="name">is.serveur.form</field>
        <field name="model">is.serveur</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archivé" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_actions"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-bolt">
                            <field name="nb_actions" widget="statinfo" string="Actions"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="date_debut_maintenance"/>
                            <field name="upgrade_auto"/>
                            <field name="fournisseur_id"/>
                            <field name="service_id"/>
                            <field name="adresse_ip"/>
                            <field name="date_creation"/>
                            <field name="date_fin"/>
                        </group>
                        <group>
                            <field name="acces_ssh"/>
                            <field name="mot_de_passe"/>
                            <field name="systeme_id"/>
                            <field name="info_systeme"/>
                            <field name="type_vps_id"/>
                            <field name="grafana"/>
                            <field name="sauvegarde"/>
                            <field name="renouvellement_auto"/>
                        </group>
                    </group>
                    <group>
                        <field name="commentaire"/>
                        <!-- <div>
                            <button name="action_import_commentaire" type="object"
                                string="Importer les actions du commentaire"
                                class="btn btn-secondary"
                            />
                        </div>-->
                    </group> 
                    <notebook>
                        <page string="Actions">
                            <field name="action_ids">
                                <list editable="bottom">
                                    <field name="date_heure"/>
                                    <field name="action"/>
                                    <field name="commentaire"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter reload_on_attachment="True"/>
            </form>
        </field>
    </record>
    <record id="is_serveur_search" model="ir.ui.view">
        <field name="name">is.serveur.search</field>
        <field name="model">is.serveur</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="fournisseur_id"/>
                <field name="acces_ssh"/>
                <field name="service_id"/>
                <field name="renouvellement_auto"/>
                <field name="systeme_id"/>
                <field name="type_vps_id"/>
                <field name="grafana"/>
                <field name="commentaire"/>
                <filter name="upgrade_auto" string="Upgrade automatique autorisé et sous maintenance" domain="[('upgrade_auto','=',True),('date_debut_maintenance','!=',False)]"/>
                <group expand="0" string="Group By...">
                    <filter name="group_by_systeme_id"     string="Système"     context="{'group_by':'systeme_id'}"/>
                    <filter name="group_by_partner_id"     string="Client"      context="{'group_by':'partner_id'}"/>
                    <filter name="group_by_fournisseur_id" string="Fournisseur" context="{'group_by':'fournisseur_id'}"/>
                    <filter name="group_by_type_vps_id"    string="Type de VPS" context="{'group_by':'type_vps_id'}"/>
                    <filter name="group_by_service_id"     string="Service"     context="{'group_by':'service_id'}"/>
                </group>
           </search>
        </field>
    </record>


    <record id="is_serveur_list" model="ir.ui.view">
        <field name="name">is.serveur.list</field>
        <field name="model">is.serveur</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"                optional="show"/>
                <field name="partner_id"          optional="show" widget="many2one_clickable"/>
                <field name="fournisseur_id"      optional="show"/>
                <field name="service_id"          optional="show"/>
                <field name="systeme_id"          optional="show"/>
                <field name="info_systeme"        optional="show"/>
                <field name="adresse_ip"          optional="show"/>
                <field name="acces_ssh"           optional="show"/>
                <field name="date_creation"       optional="show"/>
                <field name="date_fin"            optional="hide"/>
                <field name="renouvellement_auto" optional="hide"/>
                <field name="mot_de_passe"        optional="hide"/>
                <field name="type_vps_id"         optional="show"/>
                <field name="grafana"             optional="hide"/>
                <field name="sauvegarde"          optional="hide"/>
                <field name="upgrade_auto"        optional="show"/>
                <field name="commentaire"         optional="hide"/>
                <field name="date_debut_maintenance" optional="show"/>
                <field name="nb_actions"           optional="show"/>
            </list>
        </field>
    </record>
    <record id="is_serveur_action" model="ir.actions.act_window">
        <field name="name">Serveurs</field>
        <field name="res_model">is.serveur</field>
        <field name="limit">100</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="context">{'search_default_upgrade_auto': 1}</field>
    </record>

    <record id="is_serveur_graph" model="ir.ui.view">
        <field name="name">is.serveur.graph</field>
        <field name="model">is.serveur</field>
        <field name="arch" type="xml">
            <graph string="Serveurs par client" type="bar">
                <field name="partner_id" type="row"/>
                <field name="systeme_id" type="col"/>
            </graph>
        </field>
    </record>
    <record id="is_serveur_pivot" model="ir.ui.view">
        <field name="name">is.serveur.pivot</field>
        <field name="model">is.serveur</field>
        <field name="arch" type="xml">
            <pivot string="Serveurs par client">
                <field name="partner_id" type="row"/>
                <field name="systeme_id" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="is_serveur_action_action" model="ir.actions.act_window">
        <field name="name">Actions sur les serveurs</field>
        <field name="res_model">is.serveur.action</field>
        <field name="limit">100</field>
        <field name="view_mode">list,form,graph,pivot</field>
    </record>

    <!-- is.serveur.action -->
    <record id="is_serveur_action_list" model="ir.ui.view">
        <field name="name">is.serveur.action.list</field>
        <field name="model">is.serveur.action</field>
        <field name="arch" type="xml">
            <list>
                <field name="date_heure"/>
                <field name="partner_id"  optional="show"/>
                <field name="serveur_id"  optional="show"/>
                <field name="service_id"  optional="show"/>
                <field name="systeme_id"  optional="show"/>
                <field name="action"      optional="show"/>
                <field name="commentaire" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="is_serveur_action_form" model="ir.ui.view">
        <field name="name">is.serveur.action.form</field>
        <field name="model">is.serveur.action</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="date_heure"/>
                        <field name="serveur_id"/>
                        <field name="partner_id"/>
                        <field name="service_id"/>
                        <field name="systeme_id"/>
                        <field name="action"/>
                        <field name="commentaire"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="is_serveur_action_search" model="ir.ui.view">
        <field name="name">is.serveur.action.search</field>
        <field name="model">is.serveur.action</field>
        <field name="arch" type="xml">
            <search>
                <field name="serveur_id"/>
                <field name="partner_id"/>
                <field name="service_id"/>
                <field name="systeme_id"/>
                <field name="action"/>
                <field name="commentaire"/>
                <group expand="0" string="Group By...">
                    <filter name="group_by_partner_id" string="Client"  context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_service_id" string="Service" context="{'group_by': 'service_id'}"/>
                    <filter name="group_by_systeme_id" string="Système" context="{'group_by': 'systeme_id'}"/>
                    <filter name="group_by_serveur_id" string="Serveur" context="{'group_by': 'serveur_id'}"/>
                    <filter name="group_by_date_heure"  string="Date"    context="{'group_by': 'date_heure:month'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="is_serveur_action_graph" model="ir.ui.view">
        <field name="name">is.serveur.action.graph</field>
        <field name="model">is.serveur.action</field>
        <field name="arch" type="xml">
            <graph string="Actions sur les serveurs" type="bar">
                <!-- <field name="serveur_id" type="row"/> -->
                <field name="date_heure" type="row" interval="month"/>
                <field name="partner_id" type="row"/>


            </graph>
        </field>
    </record>
    <record id="is_serveur_action_pivot" model="ir.ui.view">
        <field name="name">is.serveur.action.pivot</field>
        <field name="model">is.serveur.action</field>
        <field name="arch" type="xml">
            <pivot string="Actions sur les serveurs">
                <!-- <field name="partner_id" type="col"/> -->
                <!-- <field name="serveur_id" type="row"/> -->
                <field name="date_heure" type="row" interval="month"/>
            </pivot>
        </field>
    </record>



